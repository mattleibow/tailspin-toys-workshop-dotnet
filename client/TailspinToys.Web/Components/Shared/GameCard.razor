<a href="/game/@Game.Id"
   data-testid="game-card"
   data-game-id="@Game.Id"
   data-game-title="@Game.Title"
   class="block bg-slate-800/60 backdrop-blur-sm rounded-xl border border-slate-700/50 p-6 no-underline transition-all duration-300 hover:border-blue-500/50 hover:shadow-lg hover:shadow-blue-500/10 hover:translate-y-[-6px]">
    <h3 data-testid="game-title" class="text-xl font-semibold text-slate-100 mb-3">@Game.Title</h3>
    <div class="flex flex-wrap gap-2 mb-4">
        @if (Game.Category is not null)
        {
            <span data-testid="game-category" class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-900/60 text-blue-300">
                @Game.Category.Name
            </span>
        }
        @if (Game.Publisher is not null)
        {
            <span data-testid="game-publisher" class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-purple-900/60 text-purple-300">
                @Game.Publisher.Name
            </span>
        }
    </div>
    <p data-testid="game-description" class="text-slate-300 text-sm line-clamp-3 mb-4">@TruncateDescription(Game.Description)</p>
    <span class="text-blue-400 text-sm font-medium hover:text-blue-300">View details →</span>
</a>

@code {
    [Parameter, EditorRequired]
    public Game Game { get; set; } = default!;

    private string TruncateDescription(string description)
    {
        if (string.IsNullOrEmpty(description)) return "";
        return description.Length > 150 ? description[..150] + "..." : description;
    }
}
