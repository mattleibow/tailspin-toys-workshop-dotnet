@{
    var count = Count > 0 ? Count : 6;
}

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    @for (int i = 0; i < count; i++)
    {
        <div class="bg-slate-800/60 backdrop-blur-sm rounded-xl border border-slate-700/50 p-6 animate-pulse">
            <div class="h-6 bg-slate-700 rounded w-3/4 mb-4"></div>
            <div class="flex gap-2 mb-4">
                <div class="h-5 bg-slate-700 rounded-full w-20"></div>
                <div class="h-5 bg-slate-700 rounded-full w-24"></div>
            </div>
            <div class="space-y-2">
                <div class="h-4 bg-slate-700 rounded w-full"></div>
                <div class="h-4 bg-slate-700 rounded w-5/6"></div>
                <div class="h-4 bg-slate-700 rounded w-4/6"></div>
            </div>
            <div class="mt-6 h-4 bg-slate-700 rounded w-24"></div>
        </div>
    }
</div>

@code {
    [Parameter]
    public int Count { get; set; } = 6;
}
